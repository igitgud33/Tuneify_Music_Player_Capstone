<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:padding="24dp">

    <!-- Playlist Dropdown -->
    <TextView
        android:id="@+id/textSelectPlaylist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Playlist"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:drawableEnd="@drawable/ic_dropdown"
        android:drawablePadding="8dp"
        android:background="?attr/selectableItemBackground"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Album Art Placeholder -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAlbumArt"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="40dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@+id/textPlayerTitle"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textSelectPlaylist">


        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="🎵"
            android:textSize="100sp" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/textPlayerTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:text="Title"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/textPlayerArtist" />

    <TextView
        android:id="@+id/textPlayerArtist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:text="Artist"
        android:textColor="#A0A0A0"
        android:textSize="18sp"
        app:layout_constraintBottom_toTopOf="@+id/seekBarPlayer" />

    <SeekBar
        android:id="@+id/seekBarPlayer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:progressTint="#8A65D6"
        android:thumbTint="#8A65D6"
        app:layout_constraintBottom_toTopOf="@+id/layoutTimers" />

    <LinearLayout
        android:id="@+id/layoutTimers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/btnPlayPause">

        <TextView
            android:id="@+id/textCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="#A0A0A0"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0:00"
            android:textColor="#A0A0A0"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- btns -->
    <ImageButton
        android:id="@+id/btnShuffle"
        android:src="@drawable/baseline_shuffle_24"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight=".04"
        android:text="Shuffle"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnPrevSong"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/layoutTimers"/>

    <ImageButton
        android:id="@+id/btnPrevSong"
        android:src="@drawable/ic_skip_previous"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight=".1"
        android:text="Back"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="@+id/btnShuffle"
        app:layout_constraintEnd_toStartOf="@+id/btnPlayPause"
        app:layout_constraintStart_toEndOf="@+id/btnShuffle"
        app:layout_constraintTop_toTopOf="@+id/btnShuffle"/>

    <ImageButton
        android:id="@+id/btnPlayPause"
        android:src="@drawable/ic_play"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight=".1"
        android:text="Play/Pause"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="@+id/btnShuffle"
        app:layout_constraintEnd_toStartOf="@+id/btnNextSong"
        app:layout_constraintStart_toEndOf="@+id/btnPrevSong"
        app:layout_constraintTop_toTopOf="@+id/btnShuffle"/>

    <ImageButton
        android:id="@+id/btnNextSong"
        android:src="@drawable/ic_skip_next"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight=".1"
        android:text="Next"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="@+id/btnShuffle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btnPlayPause"
        app:layout_constraintTop_toTopOf="@+id/btnShuffle"/>

</androidx.constraintlayout.widget.ConstraintLayout>
